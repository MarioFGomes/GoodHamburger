@page "/side-dishes/edit/{Id:guid}"
@inject SideDishService SideDishSvc
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Edit Side Dish — GoodHamburger</PageTitle>

<div class="d-flex align-center gap-2 mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="side-dishes" Color="Color.Default" />
    <MudText Typo="Typo.h5" Style="font-weight:700;">Edit Side Dish</MudText>
</div>

@if (_model is null && !_notFound) {
    <MudProgressLinear Indeterminate Color="Color.Warning" />
} else if (_model is not null) {
    <MudPaper Elevation="2" Class="pa-6" Style="max-width:640px;">
        <EditForm Model="_model" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />
            <MudGrid Spacing="3">
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Name" Label="Name" For="() => _model.Name"
                                  Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Description" Label="Description"
                                  Variant="Variant.Outlined" Lines="3" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="_model.Price" Label="Price" For="() => _model.Price"
                                     Variant="Variant.Outlined" Format="F2" Min="0" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect @bind-Value="_model.Category" Label="Category" Variant="Variant.Outlined">
                        @foreach (var v in Enum.GetValues<SideDishCategory>()) {
                            <MudSelectItem Value="@v">@v</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect @bind-Value="_model.Currency" Label="Currency" Variant="Variant.Outlined">
                        @foreach (var v in Enum.GetValues<Currency>()) {
                            <MudSelectItem Value="@v">@v</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect @bind-Value="_model.Status" Label="Status" Variant="Variant.Outlined">
                        @foreach (var v in Enum.GetValues<MenuStatus>()) {
                            <MudSelectItem Value="@v">@v</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
            <div class="d-flex gap-3 mt-6">
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Warning"
                           Disabled="_saving" StartIcon="@Icons.Material.Filled.Save">
                    @(_saving ? "Saving..." : "Save")
                </MudButton>
                <MudButton Href="side-dishes" Variant="Variant.Outlined" Color="Color.Default">Cancel</MudButton>
            </div>
        </EditForm>
    </MudPaper>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private UpdateSideDishesRequest? _model;
    private bool _saving;
    private bool _notFound;

    protected override async Task OnInitializedAsync() {
        var result = await SideDishSvc.GetByIdAsync(Id);
        if (result.IsSuccess && result.Data is not null) {
            var d = result.Data;
            _model = new() {
                Name = d.Name ?? "",
                Description = d.Description,
                Price = d.Price ?? 0,
                Category = d.Category,
                Currency = d.Currency,
                Status = d.Status
            };
        } else {
            _notFound = true;
            Snackbar.Add(result.ErrorMessage ?? "Side dish not found.", Severity.Error);
        }
    }

    private async Task SubmitAsync() {
        _saving = true;
        var result = await SideDishSvc.UpdateAsync(Id, _model!);
        if (result.IsSuccess) Nav.NavigateTo("/side-dishes");
        else { Snackbar.Add(result.ErrorMessage!, Severity.Error); _saving = false; }
    }
}
