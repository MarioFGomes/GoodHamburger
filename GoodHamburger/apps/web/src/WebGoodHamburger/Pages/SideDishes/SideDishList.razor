@page "/side-dishes"
@inject SideDishService SideDishSvc
@inject IJSRuntime JS

<PageTitle>Side Dishes</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Side Dishes</h2>
    <a href="side-dishes/create" class="btn btn-primary">+ New Side Dish</a>
</div>

@if (_error is not null) { <div class="alert alert-danger">@_error</div> }

@if (_loading) {
    <p><em>Loading...</em></p>
} else if (_paged is null || _paged.Items.Count == 0) {
    <p>No side dishes found.</p>
} else {
    <table class="table table-striped table-hover">
        <thead><tr><th>Name</th><th>Category</th><th>Price</th><th>Status</th><th></th></tr></thead>
        <tbody>
            @foreach (var s in _paged.Items) {
                <tr>
                    <td>@s.Name</td>
                    <td><span class="badge @(s.Category == SideDishCategory.FRIES ? "bg-warning text-dark" : "bg-info text-dark")">@s.Category</span></td>
                    <td>@s.Price?.ToString("F2") @s.Currency</td>
                    <td><span class="badge @(s.Status == MenuStatus.Available ? "bg-success" : "bg-secondary")">@s.Status</span></td>
                    <td class="text-end">
                        <a href="side-dishes/edit/@s.Id" class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(s.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <Pagination CurrentPage="_page" TotalPages="_paged.TotalPages" OnPageChange="LoadPage" />
}

@code {
    private PagedResponse<SideDishesResponse>? _paged;
    private bool _loading = true;
    private string? _error;
    private int _page = 1;

    protected override async Task OnInitializedAsync() => await LoadPage(1);

    private async Task LoadPage(int page) {
        _loading = true; _error = null; _page = page;
        var result = await SideDishSvc.GetAllAsync(page);
        if (result.IsSuccess) _paged = result.Data;
        else _error = result.ErrorMessage;
        _loading = false;
    }

    private async Task DeleteAsync(Guid id) {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this side dish?")) return;
        var result = await SideDishSvc.DeleteAsync(id);
        if (result.IsSuccess) await LoadPage(_page);
        else _error = result.ErrorMessage;
    }
}
