@page "/side-dishes"
@inject SideDishService SideDishSvc
@inject ISnackbar Snackbar
@inject IDialogService DialogSvc

<PageTitle>Side Dishes — GoodHamburger</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h5" Style="font-weight:700;">Side Dishes</MudText>
    <MudButton Href="side-dishes/create" Variant="Variant.Filled" Color="Color.Warning"
               StartIcon="@Icons.Material.Filled.Add">New Side Dish</MudButton>
</div>

<MudTable Items="@_paged?.Items" Hover="true" Loading="_loading" LoadingProgressColor="Color.Warning"
          Elevation="2" Breakpoint="Breakpoint.Sm">
    <NoRecordsContent>
        <MudText Class="pa-4" Align="Align.Center">No side dishes found.</MudText>
    </NoRecordsContent>
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Category</MudTh>
        <MudTh>Price</MudTh>
        <MudTh>Status</MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="Category">
            <MudChip Size="Size.Small"
                     Color="@(context.Category == SideDishCategory.FRIES ? Color.Warning : Color.Info)">
                @context.Category
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Price">R$ @context.Price?.ToString("F2")</MudTd>
        <MudTd DataLabel="Status">
            <MudChip Size="Size.Small"
                     Color="@(context.Status == MenuStatus.Available ? Color.Success : Color.Default)">
                @context.Status
            </MudChip>
        </MudTd>
        <MudTd>
            <div class="d-flex justify-end gap-1">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               Href="@($"side-dishes/edit/{context.Id}")" Color="Color.Default" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                               Color="Color.Error" OnClick="@(() => DeleteAsync(context.Id))" />
            </div>
        </MudTd>
    </RowTemplate>
</MudTable>

<Pagination CurrentPage="_page" TotalPages="@(_paged?.TotalPages ?? 1)" OnPageChange="LoadPage" />

@code {
    private PagedResponse<SideDishesResponse>? _paged;
    private bool _loading = true;
    private int _page = 1;

    protected override async Task OnInitializedAsync() => await LoadPage(1);

    private async Task LoadPage(int page) {
        _loading = true; _page = page;
        var result = await SideDishSvc.GetAllAsync(page);
        if (result.IsSuccess) _paged = result.Data;
        else Snackbar.Add(result.ErrorMessage!, Severity.Error);
        _loading = false;
    }

    private async Task DeleteAsync(Guid id) {
        var confirmed = await DialogSvc.ShowMessageBox(
            "Delete Side Dish", "This action cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true) return;
        var result = await SideDishSvc.DeleteAsync(id);
        if (result.IsSuccess) await LoadPage(_page);
        else Snackbar.Add(result.ErrorMessage!, Severity.Error);
    }
}
