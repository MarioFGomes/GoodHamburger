@page "/"
@using Microsoft.AspNetCore.Components.Web
@namespace WebGoodHamburger.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html class="light" lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="~/" />

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />

    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
            line-height: 1;
        }
        .textured-bg {
            background-color: #fdf8f7;
            background-image: radial-gradient(#1c1b1b05 1px, transparent 0);
            background-size: 24px 24px;
        }
    </style>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary":           "#181512",
                        "primary-container": "#2d2926",
                        "on-primary":        "#ffffff",
                        "secondary":         "#835500",
                        "secondary-container": "#feae2c",
                        "secondary-fixed":   "#ffddb4",
                        "on-background":     "#1c1b1a",
                        "surface":           "#fdf8f7",
                        "surface-variant":   "#f0ede8",
                        "outline":           "#ccc5bc",
                        "error":             "#ba1a1a"
                    },
                    fontFamily: {
                        "lexend": ["Lexend", "sans-serif"],
                        "inter":  ["Inter", "sans-serif"]
                    }
                }
            }
        }
    </script>

    <link href="css/site.css" rel="stylesheet" />
    <link href="WebGoodHamburger.styles.css" rel="stylesheet" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body class="textured-bg text-on-background font-inter min-h-screen">

    <component type="typeof(App)" render-mode="ServerPrerendered" />

    <div id="blazor-error-ui"
         style="display:none;position:fixed;bottom:0;left:0;width:100%;padding:.6rem 1.25rem;background:#fef9c3;border-top:1px solid #fde68a;z-index:9999;">
        An error occurred. <a href="" style="font-weight:600">Reload</a>
        <span class="dismiss" style="cursor:pointer;float:right">✕</span>
    </div>

    <script src="_framework/blazor.server.js"></script>
</body>
</html>
