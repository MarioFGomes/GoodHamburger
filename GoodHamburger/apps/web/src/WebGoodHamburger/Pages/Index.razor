@page "/"
@inject CustomerService CustomerSvc
@inject MenuService MenuSvc
@inject SideDishService SideDishSvc
@inject OrderService OrderSvc

<PageTitle>Good Hamburger — Dashboard</PageTitle>

<h1 class="mb-4">Dashboard</h1>

@if (_loading) {
    <p><em>Loading...</em></p>
} else {
    <div class="row g-4">
        <div class="col-sm-6 col-lg-3">
            <div class="card text-white bg-primary h-100">
                <div class="card-body">
                    <h5 class="card-title">Customers</h5>
                    <p class="display-4">@_customers</p>
                </div>
                <div class="card-footer"><a href="customers" class="text-white">View all →</a></div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card text-white bg-success h-100">
                <div class="card-body">
                    <h5 class="card-title">Menus</h5>
                    <p class="display-4">@_menus</p>
                </div>
                <div class="card-footer"><a href="menus" class="text-white">View all →</a></div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card text-white bg-warning h-100">
                <div class="card-body">
                    <h5 class="card-title">Side Dishes</h5>
                    <p class="display-4">@_sideDishes</p>
                </div>
                <div class="card-footer"><a href="side-dishes" class="text-white">View all →</a></div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card text-white bg-danger h-100">
                <div class="card-body">
                    <h5 class="card-title">Orders</h5>
                    <p class="display-4">@_orders</p>
                </div>
                <div class="card-footer"><a href="orders" class="text-white">View all →</a></div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private int _customers, _menus, _sideDishes, _orders;

    protected override async Task OnInitializedAsync() {
        var c = await CustomerSvc.GetAllAsync(1, 1);
        var m = await MenuSvc.GetAllAsync(1, 1);
        var s = await SideDishSvc.GetAllAsync(1, 1);
        var o = await OrderSvc.GetAllAsync(1, 1);

        if (c.IsSuccess) _customers = c.Data!.TotalItems;
        if (m.IsSuccess) _menus = m.Data!.TotalItems;
        if (s.IsSuccess) _sideDishes = s.Data!.TotalItems;
        if (o.IsSuccess) _orders = o.Data!.TotalItems;

        _loading = false;
    }
}
