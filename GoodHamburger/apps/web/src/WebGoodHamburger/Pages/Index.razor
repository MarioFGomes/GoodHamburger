@page "/"
@inject CustomerService CustomerSvc
@inject MenuService MenuSvc
@inject SideDishService SideDishSvc
@inject OrderService OrderSvc

<PageTitle>Dashboard — GoodHamburger</PageTitle>

<MudText Typo="Typo.h5" Class="mb-6" Style="font-weight:700;">Dashboard</MudText>

@if (_loading) {
    <MudProgressLinear Indeterminate Color="Color.Warning" />
} else {
    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" lg="3">
            <MudCard Elevation="2">
                <MudCardContent>
                    <div class="d-flex align-center gap-4">
                        <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Warning" Size="Size.Large" />
                        <div>
                            <MudText Typo="Typo.h4" Style="font-weight:700;">@_customers</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Customers</MudText>
                        </div>
                    </div>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Href="customers" Color="Color.Warning" Variant="Variant.Text"
                               EndIcon="@Icons.Material.Filled.ArrowForward">View all</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudCard Elevation="2">
                <MudCardContent>
                    <div class="d-flex align-center gap-4">
                        <MudIcon Icon="@Icons.Material.Filled.MenuBook" Color="Color.Warning" Size="Size.Large" />
                        <div>
                            <MudText Typo="Typo.h4" Style="font-weight:700;">@_menus</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Menus</MudText>
                        </div>
                    </div>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Href="menus" Color="Color.Warning" Variant="Variant.Text"
                               EndIcon="@Icons.Material.Filled.ArrowForward">View all</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudCard Elevation="2">
                <MudCardContent>
                    <div class="d-flex align-center gap-4">
                        <MudIcon Icon="@Icons.Material.Filled.RiceBowl" Color="Color.Warning" Size="Size.Large" />
                        <div>
                            <MudText Typo="Typo.h4" Style="font-weight:700;">@_sideDishes</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Side Dishes</MudText>
                        </div>
                    </div>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Href="side-dishes" Color="Color.Warning" Variant="Variant.Text"
                               EndIcon="@Icons.Material.Filled.ArrowForward">View all</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudCard Elevation="2">
                <MudCardContent>
                    <div class="d-flex align-center gap-4">
                        <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Warning" Size="Size.Large" />
                        <div>
                            <MudText Typo="Typo.h4" Style="font-weight:700;">@_orders</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Orders</MudText>
                        </div>
                    </div>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Href="orders" Color="Color.Warning" Variant="Variant.Text"
                               EndIcon="@Icons.Material.Filled.ArrowForward">View all</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    private bool _loading = true;
    private int _customers, _menus, _sideDishes, _orders;

    protected override async Task OnInitializedAsync() {
        var c = await CustomerSvc.GetAllAsync(1, 1);
        var m = await MenuSvc.GetAllAsync(1, 1);
        var s = await SideDishSvc.GetAllAsync(1, 1);
        var o = await OrderSvc.GetAllAsync(1, 1);

        if (c.IsSuccess) _customers = c.Data!.TotalItems;
        if (m.IsSuccess) _menus = m.Data!.TotalItems;
        if (s.IsSuccess) _sideDishes = s.Data!.TotalItems;
        if (o.IsSuccess) _orders = o.Data!.TotalItems;

        _loading = false;
    }
}
