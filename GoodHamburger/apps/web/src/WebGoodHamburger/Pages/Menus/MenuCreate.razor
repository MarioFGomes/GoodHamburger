@page "/menus/create"
@inject MenuService MenuSvc
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>New Menu — GoodHamburger</PageTitle>

<div class="d-flex align-center gap-2 mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="menus" Color="Color.Default" />
    <MudText Typo="Typo.h5" Style="font-weight:700;">New Menu</MudText>
</div>

<MudPaper Elevation="2" Class="pa-6" Style="max-width:640px;">
    <EditForm Model="_model" OnValidSubmit="SubmitAsync">
        <DataAnnotationsValidator />
        <MudGrid Spacing="3">
            <MudItem xs="12">
                <MudTextField @bind-Value="_model.Name" Label="Name" For="() => _model.Name"
                              Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_model.Description" Label="Description"
                              Variant="Variant.Outlined" Lines="3" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="_model.Price" Label="Price" For="() => _model.Price"
                                 Variant="Variant.Outlined" Format="F2" Min="0" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="_model.Currency" Label="Currency" Variant="Variant.Outlined">
                    @foreach (var v in Enum.GetValues<Currency>()) {
                        <MudSelectItem Value="@v">@v</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>
        <div class="d-flex gap-3 mt-6">
            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Warning"
                       Disabled="_saving" StartIcon="@Icons.Material.Filled.Save">
                @(_saving ? "Saving..." : "Create")
            </MudButton>
            <MudButton Href="menus" Variant="Variant.Outlined" Color="Color.Default">Cancel</MudButton>
        </div>
    </EditForm>
</MudPaper>

@code {
    private readonly CreateMenuRequest _model = new();
    private bool _saving;

    private async Task SubmitAsync() {
        _saving = true;
        var result = await MenuSvc.CreateAsync(_model);
        if (result.IsSuccess) Nav.NavigateTo("/menus");
        else { Snackbar.Add(result.ErrorMessage!, Severity.Error); _saving = false; }
    }
}
