@page "/menus"
@inject MenuService MenuSvc
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Menus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Menus</h2>
    <a href="menus/create" class="btn btn-primary">+ New Menu</a>
</div>

@if (_error is not null) { <div class="alert alert-danger">@_error</div> }

@if (_loading) {
    <p><em>Loading...</em></p>
} else if (_paged is null || _paged.Items.Count == 0) {
    <p>No menus found.</p>
} else {
    <table class="table table-striped table-hover">
        <thead><tr><th>Name</th><th>Price</th><th>Currency</th><th>Status</th><th></th></tr></thead>
        <tbody>
            @foreach (var m in _paged.Items) {
                <tr>
                    <td>@m.Name</td>
                    <td>@m.Price?.ToString("F2")</td>
                    <td>@m.Currency</td>
                    <td><span class="badge @(m.Status == MenuStatus.Available ? "bg-success" : "bg-secondary")">@m.Status</span></td>
                    <td class="text-end">
                        <a href="menus/edit/@m.Id" class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(m.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <Pagination CurrentPage="_page" TotalPages="_paged.TotalPages" OnPageChange="LoadPage" />
}

@code {
    private PagedResponse<MenuResponse>? _paged;
    private bool _loading = true;
    private string? _error;
    private int _page = 1;

    protected override async Task OnInitializedAsync() => await LoadPage(1);

    private async Task LoadPage(int page) {
        _loading = true; _error = null; _page = page;
        var result = await MenuSvc.GetAllAsync(page);
        if (result.IsSuccess) _paged = result.Data;
        else _error = result.ErrorMessage;
        _loading = false;
    }

    private async Task DeleteAsync(Guid id) {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this menu?")) return;
        var result = await MenuSvc.DeleteAsync(id);
        if (result.IsSuccess) await LoadPage(_page);
        else _error = result.ErrorMessage;
    }
}
