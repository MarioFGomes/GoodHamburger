@page "/customers"
@inject CustomerService CustomerSvc
@inject ISnackbar Snackbar
@inject IDialogService DialogSvc

<PageTitle>Customers — GoodHamburger</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h5" Style="font-weight:700;">Customers</MudText>
    <MudButton Href="customers/create" Variant="Variant.Filled" Color="Color.Warning"
               StartIcon="@Icons.Material.Filled.PersonAdd">New Customer</MudButton>
</div>

<MudTable Items="@_paged?.Items" Hover="true" Loading="_loading" LoadingProgressColor="Color.Warning"
          Elevation="2" Breakpoint="Breakpoint.Sm">
    <NoRecordsContent>
        <MudText Class="pa-4" Align="Align.Center">No customers found.</MudText>
    </NoRecordsContent>
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Email</MudTh>
        <MudTh>Phone</MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.FirstName @context.LastName</MudTd>
        <MudTd DataLabel="Email">@context.Email</MudTd>
        <MudTd DataLabel="Phone">@context.Phone</MudTd>
        <MudTd>
            <div class="d-flex justify-end gap-1">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               Href="@($"customers/edit/{context.Id}")" Color="Color.Default" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                               Color="Color.Error" OnClick="@(() => DeleteAsync(context.Id))" />
            </div>
        </MudTd>
    </RowTemplate>
</MudTable>

<Pagination CurrentPage="_page" TotalPages="@(_paged?.TotalPages ?? 1)" OnPageChange="LoadPage" />

@code {
    private PagedResponse<CustomerResponse>? _paged;
    private bool _loading = true;
    private int _page = 1;

    protected override async Task OnInitializedAsync() => await LoadPage(1);

    private async Task LoadPage(int page) {
        _loading = true; _page = page;
        var result = await CustomerSvc.GetAllAsync(page);
        if (result.IsSuccess) _paged = result.Data;
        else Snackbar.Add(result.ErrorMessage!, Severity.Error);
        _loading = false;
    }

    private async Task DeleteAsync(Guid id) {
        var confirmed = await DialogSvc.ShowMessageBox(
            "Delete Customer", "This action cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true) return;
        var result = await CustomerSvc.DeleteAsync(id);
        if (result.IsSuccess) await LoadPage(_page);
        else Snackbar.Add(result.ErrorMessage!, Severity.Error);
    }
}
