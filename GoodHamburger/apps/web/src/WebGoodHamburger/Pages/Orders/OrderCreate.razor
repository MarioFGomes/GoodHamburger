@page "/orders/create"
@inject OrderService OrderSvc
@inject CustomerService CustomerSvc
@inject MenuService MenuSvc
@inject SideDishService SideDishSvc
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>New Order — GoodHamburger</PageTitle>

<div class="d-flex align-center gap-2 mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="orders" Color="Color.Default" />
    <div>
        <MudText Typo="Typo.h5" Style="font-weight:700;">New Order</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Select a customer, sandwich and optional side dishes</MudText>
    </div>
</div>

@if (_loading) {
    <MudProgressLinear Indeterminate Color="Color.Warning" />
} else {
    <MudPaper Elevation="2" Class="pa-6" Style="max-width:680px;">
        <EditForm Model="_model" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />
            <MudGrid Spacing="3">

                <MudItem xs="12">
                    <MudSelect @bind-Value="_model.CustomerId" Label="Customer"
                               For="() => _model.CustomerId" Variant="Variant.Outlined" Required="true">
                        @foreach (var c in _customers) {
                            <MudSelectItem Value="@c.Id">@c.FirstName @c.LastName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudSelect @bind-Value="_model.MenuId" Label="Sandwich"
                               For="() => _model.MenuId" Variant="Variant.Outlined" Required="true">
                        @foreach (var m in _menus) {
                            <MudSelectItem Value="@m.Id">@m.Name — R$ @m.Price?.ToString("F2")</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                @if (_sideDishes.Any()) {
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Class="mb-1">Side Dishes</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
                            Maximum 1 FRIES + 1 DRINK — adds a discount
                        </MudText>
                        @foreach (var s in _sideDishes) {
                            var sd = s;
                            <MudPaper Outlined="true"
                                      Class="@($"pa-3 mb-2 rounded {(_model.SideDishIds.Contains(sd.Id) ? "mud-border-warning" : "")}")"
                                      Style="@(_model.SideDishIds.Contains(sd.Id) ? "background:rgba(254,174,44,0.08);" : "")">
                                <div class="d-flex align-center gap-3">
                                    <MudCheckBox Value="@_model.SideDishIds.Contains(sd.Id)"
                                                 ValueChanged="@((bool v) => ToggleSideDish(sd.Id, v))"
                                                 Color="Color.Warning" />
                                    <MudIcon Icon="@(sd.Category == SideDishCategory.FRIES ? Icons.Material.Filled.Fastfood : Icons.Material.Filled.LocalDrink)"
                                             Color="@(sd.Category == SideDishCategory.FRIES ? Color.Warning : Color.Info)"
                                             Size="Size.Small" />
                                    <MudText Typo="Typo.body2" Style="flex:1;">@sd.Name</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">R$ @sd.Price?.ToString("F2")</MudText>
                                </div>
                            </MudPaper>
                        }
                    </MudItem>
                }

                <MudItem xs="12">
                    <MudPaper Outlined="true" Class="pa-4 rounded">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Discount rules</MudText>
                        <div class="d-flex align-center gap-2 mb-1">
                            <MudIcon Icon="@Icons.Material.Filled.Fastfood" Color="Color.Warning" Size="Size.Small" />
                            <MudText Typo="Typo.body2">1 FRIES only → <strong style="color:#16a34a;">10% off</strong></MudText>
                        </div>
                        <div class="d-flex align-center gap-2 mb-1">
                            <MudIcon Icon="@Icons.Material.Filled.LocalDrink" Color="Color.Info" Size="Size.Small" />
                            <MudText Typo="Typo.body2">1 DRINK only → <strong style="color:#16a34a;">15% off</strong></MudText>
                        </div>
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Restaurant" Color="Color.Secondary" Size="Size.Small" />
                            <MudText Typo="Typo.body2">FRIES + DRINK combo → <strong style="color:#16a34a;">20% off</strong></MudText>
                        </div>
                    </MudPaper>
                </MudItem>

            </MudGrid>

            <div class="d-flex gap-3 mt-6">
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Warning"
                           Disabled="_saving" StartIcon="@Icons.Material.Filled.AddShoppingCart">
                    @(_saving ? "Placing order..." : "Place Order")
                </MudButton>
                <MudButton Href="orders" Variant="Variant.Outlined" Color="Color.Default">Cancel</MudButton>
            </div>
        </EditForm>
    </MudPaper>
}

@code {
    private readonly CreateOrderRequest _model = new();
    private List<CustomerResponse> _customers = new();
    private List<MenuResponse> _menus = new();
    private List<SideDishesResponse> _sideDishes = new();
    private bool _loading = true;
    private bool _saving;

    protected override async Task OnInitializedAsync() {
        var c = await CustomerSvc.GetAllAsync(1, 100);
        var m = await MenuSvc.GetAllAsync(1, 100);
        var s = await SideDishSvc.GetAllAsync(1, 100);
        if (c.IsSuccess) _customers = c.Data!.Items;
        if (m.IsSuccess) _menus = m.Data!.Items;
        if (s.IsSuccess) _sideDishes = s.Data!.Items;
        _loading = false;
    }

    private void ToggleSideDish(Guid id, bool selected) {
        if (selected) _model.SideDishIds.Add(id);
        else _model.SideDishIds.Remove(id);
    }

    private async Task SubmitAsync() {
        _saving = true;
        var result = await OrderSvc.CreateAsync(_model);
        if (result.IsSuccess) Nav.NavigateTo($"/orders/{result.Data!.Id}");
        else { Snackbar.Add(result.ErrorMessage!, Severity.Error); _saving = false; }
    }
}
