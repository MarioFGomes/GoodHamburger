@page "/orders/create"
@inject OrderService OrderSvc
@inject CustomerService CustomerSvc
@inject MenuService MenuSvc
@inject SideDishService SideDishSvc
@inject NavigationManager Nav

<PageTitle>New Order — GoodHamburger</PageTitle>

<Toast @ref="_toast" />

<div class="max-w-2xl mx-auto space-y-6">

    <div class="flex items-center gap-4">
        <a href="/orders" class="p-2 hover:bg-stone-100 rounded-lg transition-colors text-zinc-500">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-zinc-900 font-lexend">New Order</h1>
            <p class="text-sm text-zinc-500 mt-0.5">Select a customer, sandwich and optional side dishes</p>
        </div>
    </div>

    @if (_loading) {
        <div class="flex items-center justify-center py-16">
            <div class="flex items-center gap-3 text-zinc-400">
                <span class="material-symbols-outlined animate-spin">refresh</span>
                <span class="text-sm">Loading data...</span>
            </div>
        </div>
    } else {
        <div class="bg-white rounded-xl shadow-sm border border-zinc-100 p-6">
            <EditForm Model="_model" OnValidSubmit="SubmitAsync">
                <DataAnnotationsValidator />
                <div class="space-y-5">

                    <div class="space-y-1">
                        <label class="block text-sm font-medium text-zinc-700">Customer</label>
                        <InputSelect class="gh-select" @bind-Value="_model.CustomerId">
                            <option value="@Guid.Empty">— Select customer —</option>
                            @foreach (var c in _customers) {
                                <option value="@c.Id">@c.FirstName @c.LastName</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => _model.CustomerId" />
                    </div>

                    <div class="space-y-1">
                        <label class="block text-sm font-medium text-zinc-700">Sandwich</label>
                        <InputSelect class="gh-select" @bind-Value="_model.MenuId">
                            <option value="@Guid.Empty">— Select sandwich —</option>
                            @foreach (var m in _menus) {
                                <option value="@m.Id">@m.Name — R$ @m.Price?.ToString("F2")</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => _model.MenuId" />
                    </div>

                    @if (_sideDishes.Any()) {
                        <div class="space-y-2">
                            <div>
                                <label class="block text-sm font-medium text-zinc-700">Side Dishes</label>
                                <p class="text-xs text-zinc-400 mt-0.5">Maximum 1 FRIES + 1 DRINK — adds a discount</p>
                            </div>
                            <div class="grid grid-cols-1 gap-2">
                                @foreach (var s in _sideDishes) {
                                    var isChecked = _model.SideDishIds.Contains(s.Id);
                                    <label class="flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition-colors
                                        @(isChecked ? "border-amber-300 bg-amber-50" : "border-zinc-100 bg-zinc-50 hover:bg-stone-50")">
                                        <input type="checkbox"
                                               class="w-4 h-4 rounded accent-amber-500"
                                               checked="@isChecked"
                                               @onchange="e => ToggleSideDish(s.Id, (bool)e.Value!)" />
                                        <div class="flex items-center gap-2 flex-1 min-w-0">
                                            <div class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0
                                                @(s.Category == SideDishCategory.FRIES ? "bg-amber-100" : "bg-blue-100")">
                                                <span class="material-symbols-outlined @(s.Category == SideDishCategory.FRIES ? "text-amber-600" : "text-blue-500")"
                                                      style="font-size:14px;font-variation-settings:'FILL' 1">
                                                    @(s.Category == SideDishCategory.FRIES ? "fastfood" : "local_drink")
                                                </span>
                                            </div>
                                            <span class="text-sm font-medium text-zinc-800">@s.Name</span>
                                            <span class="text-xs text-zinc-400 ml-auto shrink-0">R$ @s.Price?.ToString("F2")</span>
                                        </div>
                                    </label>
                                }
                            </div>
                        </div>
                    }

                    <div class="rounded-xl bg-stone-50 border border-zinc-100 p-4 space-y-1.5 text-sm">
                        <p class="font-medium text-zinc-700 mb-2">Discount rules</p>
                        <div class="flex items-center gap-2 text-zinc-500">
                            <span class="material-symbols-outlined text-amber-500" style="font-size:16px">fastfood</span>
                            <span>1 FRIES only → <span class="font-semibold text-emerald-600">10% off</span></span>
                        </div>
                        <div class="flex items-center gap-2 text-zinc-500">
                            <span class="material-symbols-outlined text-blue-500" style="font-size:16px">local_drink</span>
                            <span>1 DRINK only → <span class="font-semibold text-emerald-600">15% off</span></span>
                        </div>
                        <div class="flex items-center gap-2 text-zinc-500">
                            <span class="material-symbols-outlined text-violet-500" style="font-size:16px">restaurant</span>
                            <span>FRIES + DRINK combo → <span class="font-semibold text-emerald-600">20% off</span></span>
                        </div>
                    </div>

                </div>

                <div class="flex gap-3 mt-6 pt-6 border-t border-zinc-100">
                    <button type="submit" class="gh-btn gh-btn-primary" disabled="@_saving">
                        @if (_saving) {
                            <span class="material-symbols-outlined animate-spin" style="font-size:16px">refresh</span>
                            <span>Placing order...</span>
                        } else {
                            <span class="material-symbols-outlined" style="font-size:16px">add_shopping_cart</span>
                            <span>Place Order</span>
                        }
                    </button>
                    <a href="/orders" class="gh-btn gh-btn-secondary">Cancel</a>
                </div>
            </EditForm>
        </div>
    }

</div>

@code {
    private Toast _toast = default!;
    private readonly CreateOrderRequest _model = new();
    private List<CustomerResponse> _customers = new();
    private List<MenuResponse> _menus = new();
    private List<SideDishesResponse> _sideDishes = new();
    private bool _loading = true;
    private bool _saving;

    protected override async Task OnInitializedAsync() {
        var c = await CustomerSvc.GetAllAsync(1, 100);
        var m = await MenuSvc.GetAllAsync(1, 100);
        var s = await SideDishSvc.GetAllAsync(1, 100);
        if (c.IsSuccess) _customers = c.Data!.Items;
        if (m.IsSuccess) _menus = m.Data!.Items;
        if (s.IsSuccess) _sideDishes = s.Data!.Items;
        _loading = false;
    }

    private void ToggleSideDish(Guid id, bool selected) {
        if (selected) _model.SideDishIds.Add(id);
        else _model.SideDishIds.Remove(id);
    }

    private async Task SubmitAsync() {
        _saving = true;
        var result = await OrderSvc.CreateAsync(_model);
        if (result.IsSuccess) Nav.NavigateTo($"/orders/{result.Data!.Id}");
        else { await _toast.ShowAsync(result.ErrorMessage!); _saving = false; }
    }
}
