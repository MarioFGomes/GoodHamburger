@page "/orders"
@inject OrderService OrderSvc
@inject IJSRuntime JS

<PageTitle>Orders</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Orders</h2>
    <a href="orders/create" class="btn btn-primary">+ New Order</a>
</div>

@if (_error is not null) { <div class="alert alert-danger">@_error</div> }

@if (_loading) {
    <p><em>Loading...</em></p>
} else if (_paged is null || _paged.Items.Count == 0) {
    <p>No orders found.</p>
} else {
    <table class="table table-striped table-hover">
        <thead><tr><th>#</th><th>Customer</th><th>Total</th><th>Discount</th><th>Status</th><th></th></tr></thead>
        <tbody>
            @foreach (var o in _paged.Items) {
                <tr>
                    <td>@o.OrderNumber</td>
                    <td>@o.CustomerId</td>
                    <td>@o.Total.ToString("F2")</td>
                    <td>@o.Discount%</td>
                    <td><span class="badge @StatusBadge(o.Status)">@o.Status</span></td>
                    <td class="text-end">
                        <a href="orders/@o.Id" class="btn btn-sm btn-outline-primary me-1">Detail</a>
                        @if (o.Status == OrderStatus.PENDING || o.Status == OrderStatus.CANCELLED) {
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(o.Id)">Delete</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <Pagination CurrentPage="_page" TotalPages="_paged.TotalPages" OnPageChange="LoadPage" />
}

@code {
    private PagedResponse<OrderResponse>? _paged;
    private bool _loading = true;
    private string? _error;
    private int _page = 1;

    protected override async Task OnInitializedAsync() => await LoadPage(1);

    private async Task LoadPage(int page) {
        _loading = true; _error = null; _page = page;
        var result = await OrderSvc.GetAllAsync(page);
        if (result.IsSuccess) _paged = result.Data;
        else _error = result.ErrorMessage;
        _loading = false;
    }

    private async Task DeleteAsync(Guid id) {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this order?")) return;
        var result = await OrderSvc.DeleteAsync(id);
        if (result.IsSuccess) await LoadPage(_page);
        else _error = result.ErrorMessage;
    }

    private static string StatusBadge(OrderStatus s) => s switch {
        OrderStatus.PENDING => "bg-warning text-dark",
        OrderStatus.CONFIRMED => "bg-primary",
        OrderStatus.CANCELLED => "bg-secondary",
        OrderStatus.PAID => "bg-success",
        OrderStatus.READY => "bg-info text-dark",
        OrderStatus.DELIVERED => "bg-dark",
        _ => "bg-secondary"
    };
}
