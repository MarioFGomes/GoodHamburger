@page "/orders"
@inject OrderService OrderSvc
@inject ISnackbar Snackbar
@inject IDialogService DialogSvc

<PageTitle>Orders — GoodHamburger</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h5" Style="font-weight:700;">Orders</MudText>
    <MudButton Href="orders/create" Variant="Variant.Filled" Color="Color.Warning"
               StartIcon="@Icons.Material.Filled.AddShoppingCart">New Order</MudButton>
</div>

<MudTable Items="@_paged?.Items" Hover="true" Loading="_loading" LoadingProgressColor="Color.Warning"
          Elevation="2" Breakpoint="Breakpoint.Sm">
    <NoRecordsContent>
        <MudText Class="pa-4" Align="Align.Center">No orders yet.</MudText>
    </NoRecordsContent>
    <HeaderContent>
        <MudTh>Order</MudTh>
        <MudTh>Customer</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Discount</MudTh>
        <MudTh Style="text-align:right;">Total</MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Order">
            <MudText Typo="Typo.body2" Style="font-weight:700;">#GH-@context.OrderNumber</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.CreatedAt.ToString("dd MMM yyyy, HH:mm")</MudText>
        </MudTd>
        <MudTd DataLabel="Customer">
            @(string.IsNullOrEmpty(context.CustomerName) ? "—" : context.CustomerName)
        </MudTd>
        <MudTd DataLabel="Status">
            <MudChip Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
        </MudTd>
        <MudTd DataLabel="Discount">
            @if (context.Discount > 0) {
                <MudText Color="Color.Success" Style="font-weight:600;">-@context.Discount%</MudText>
            } else {
                <MudText Color="Color.Secondary">—</MudText>
            }
        </MudTd>
        <MudTd DataLabel="Total" Style="text-align:right;font-weight:700;">
            R$ @context.Total.ToString("F2")
        </MudTd>
        <MudTd>
            <div class="d-flex justify-end gap-1">
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                               Href="@($"orders/{context.Id}")" Color="Color.Default" />
                @if (context.Status == OrderStatus.PENDING || context.Status == OrderStatus.CANCELLED) {
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                   Color="Color.Error" OnClick="@(() => DeleteAsync(context.Id))" />
                }
            </div>
        </MudTd>
    </RowTemplate>
</MudTable>

<Pagination CurrentPage="_page" TotalPages="@(_paged?.TotalPages ?? 1)" OnPageChange="LoadPage" />

@code {
    private PagedResponse<OrderResponse>? _paged;
    private bool _loading = true;
    private int _page = 1;

    protected override async Task OnInitializedAsync() => await LoadPage(1);

    private async Task LoadPage(int page) {
        _loading = true; _page = page;
        var result = await OrderSvc.GetAllAsync(page);
        if (result.IsSuccess) _paged = result.Data;
        else Snackbar.Add(result.ErrorMessage!, Severity.Error);
        _loading = false;
    }

    private async Task DeleteAsync(Guid id) {
        var confirmed = await DialogSvc.ShowMessageBox(
            "Delete Order", "This action cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true) return;
        var result = await OrderSvc.DeleteAsync(id);
        if (result.IsSuccess) await LoadPage(_page);
        else Snackbar.Add(result.ErrorMessage!, Severity.Error);
    }

    private static Color GetStatusColor(OrderStatus s) => s switch {
        OrderStatus.PENDING   => Color.Warning,
        OrderStatus.CONFIRMED => Color.Info,
        OrderStatus.CANCELLED => Color.Default,
        OrderStatus.PAID      => Color.Success,
        OrderStatus.READY     => Color.Tertiary,
        OrderStatus.DELIVERED => Color.Dark,
        _                     => Color.Default
    };
}
