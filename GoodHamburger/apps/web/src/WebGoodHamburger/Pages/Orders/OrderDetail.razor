@page "/orders/{Id:guid}"
@inject OrderService OrderSvc
@inject ISnackbar Snackbar

<PageTitle>Order Detail — GoodHamburger</PageTitle>

<div class="d-flex align-center gap-2 mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="orders" Color="Color.Default" />
    <div>
        <MudText Typo="Typo.h5" Style="font-weight:700;">Order Detail</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">View and manage this order</MudText>
    </div>
</div>

@if (_order is null) {
    <MudProgressLinear Indeterminate Color="Color.Warning" />
} else {
    <MudGrid Spacing="3">

        <MudItem xs="12">
            <MudPaper Elevation="2" Class="pa-5">
                <div class="d-flex flex-wrap justify-space-between align-start gap-4">
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                 Style="text-transform:uppercase;letter-spacing:1px;">Order</MudText>
                        <MudText Typo="Typo.h5" Style="font-weight:700;">#GH-@_order.OrderNumber</MudText>
                        <div class="d-flex align-center gap-1 mt-1">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.body2">
                                @(string.IsNullOrEmpty(_order.CustomerName) ? "Unknown customer" : _order.CustomerName)
                            </MudText>
                        </div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @_order.CreatedAt.ToString("dd MMM yyyy, HH:mm")
                        </MudText>
                        <div class="mt-2">
                            <MudChip Size="Size.Small" Color="@GetStatusColor(_order.Status)">@_order.Status</MudChip>
                        </div>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        @if (_order.Status == OrderStatus.PENDING) {
                            <MudButton Variant="Variant.Filled" Color="Color.Warning"
                                       StartIcon="@Icons.Material.Filled.CheckCircle"
                                       OnClick="ConfirmAsync" Disabled="_busy">Confirm</MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.Cancel"
                                       OnClick="CancelAsync" Disabled="_busy">Cancel</MudButton>
                        } else if (_order.Status == OrderStatus.CONFIRMED) {
                            <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.Cancel"
                                       OnClick="CancelAsync" Disabled="_busy">Cancel</MudButton>
                        }
                    </div>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="4">
            <MudPaper Elevation="2" Class="pa-4">
                <MudText Typo="Typo.caption" Color="Color.Secondary"
                         Style="text-transform:uppercase;letter-spacing:1px;">Subtotal</MudText>
                <MudText Typo="Typo.h6" Style="font-weight:700;">R$ @_order.Subtotal.ToString("F2")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="2" Class="pa-4">
                <MudText Typo="Typo.caption" Color="Color.Secondary"
                         Style="text-transform:uppercase;letter-spacing:1px;">Discount</MudText>
                @if (_order.Discount > 0) {
                    <MudText Typo="Typo.h6" Style="font-weight:700;color:#16a34a;">-@_order.Discount%</MudText>
                } else {
                    <MudText Typo="Typo.h6" Color="Color.Secondary">—</MudText>
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="2" Class="pa-4" Style="background:#181512;">
                <MudText Typo="Typo.caption"
                         Style="text-transform:uppercase;letter-spacing:1px;color:#feae2c;">Total</MudText>
                <MudText Typo="Typo.h6" Style="font-weight:700;color:white;">
                    R$ @_order.Total.ToString("F2")
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <MudPaper Elevation="2">
                <div class="pa-4 pb-2">
                    <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Order Items</MudText>
                </div>
                <MudDivider />
                @foreach (var item in _order.Items) {
                    <div class="pa-4">
                        <div class="d-flex align-start gap-4">
                            <MudAvatar Style="background:rgba(254,174,44,0.15);">
                                <MudIcon Icon="@Icons.Material.Filled.LunchDining" Color="Color.Warning" />
                            </MudAvatar>
                            <div style="flex:1;min-width:0;">
                                <div class="d-flex justify-space-between gap-2">
                                    <MudText Typo="Typo.body1" Style="font-weight:600;">
                                        @(string.IsNullOrEmpty(item.MenuName) ? "Sandwich" : item.MenuName)
                                    </MudText>
                                    <MudText Typo="Typo.body1" Style="font-weight:700;">
                                        R$ @item.UnitPrice.ToString("F2")
                                    </MudText>
                                </div>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Qty: @item.Qtd</MudText>

                                @if (item.SideDishes.Any()) {
                                    <MudText Typo="Typo.caption" Class="mt-3 mb-1"
                                             Style="text-transform:uppercase;letter-spacing:1px;font-weight:600;">
                                        Side Dishes
                                    </MudText>
                                    @foreach (var sd in item.SideDishes) {
                                        <MudPaper Outlined="true" Class="pa-2 mb-1 rounded">
                                            <div class="d-flex align-center gap-3">
                                                <MudIcon Icon="@(sd.Category == SideDishCategory.FRIES ? Icons.Material.Filled.Fastfood : Icons.Material.Filled.LocalDrink)"
                                                         Color="@(sd.Category == SideDishCategory.FRIES ? Color.Warning : Color.Info)"
                                                         Size="Size.Small" />
                                                <MudText Typo="Typo.body2" Style="flex:1;">
                                                    @(string.IsNullOrEmpty(sd.Name) ? sd.Category.ToString() : sd.Name)
                                                </MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Qty: @sd.Qtd</MudText>
                                                <MudText Typo="Typo.body2" Style="font-weight:600;">
                                                    R$ @sd.UnitPrice.ToString("F2")
                                                </MudText>
                                            </div>
                                        </MudPaper>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                    <MudDivider />
                }
            </MudPaper>
        </MudItem>

    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private OrderResponse? _order;
    private bool _busy;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync() {
        var result = await OrderSvc.GetByIdAsync(Id);
        if (result.IsSuccess) _order = result.Data;
        else Snackbar.Add(result.ErrorMessage!, Severity.Error);
    }

    private async Task ConfirmAsync() {
        _busy = true;
        var result = await OrderSvc.ConfirmAsync(Id);
        if (result.IsSuccess) _order = result.Data;
        else Snackbar.Add(result.ErrorMessage!, Severity.Error);
        _busy = false;
    }

    private async Task CancelAsync() {
        _busy = true;
        var result = await OrderSvc.CancelAsync(Id);
        if (result.IsSuccess) _order = result.Data;
        else Snackbar.Add(result.ErrorMessage!, Severity.Error);
        _busy = false;
    }

    private static Color GetStatusColor(OrderStatus s) => s switch {
        OrderStatus.PENDING   => Color.Warning,
        OrderStatus.CONFIRMED => Color.Info,
        OrderStatus.CANCELLED => Color.Default,
        OrderStatus.PAID      => Color.Success,
        OrderStatus.READY     => Color.Tertiary,
        OrderStatus.DELIVERED => Color.Dark,
        _                     => Color.Default
    };
}
