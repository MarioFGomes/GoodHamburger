@page "/orders/{Id:guid}"
@inject OrderService OrderSvc
@inject NavigationManager Nav

<PageTitle>Order Detail — GoodHamburger</PageTitle>

<Toast @ref="_toast" />

<div class="max-w-3xl mx-auto space-y-6">

    <div class="flex items-center gap-4">
        <a href="/orders" class="p-2 hover:bg-stone-100 rounded-lg transition-colors text-zinc-500">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-zinc-900 font-lexend">Order Detail</h1>
            <p class="text-sm text-zinc-500 mt-0.5">View and manage this order</p>
        </div>
    </div>

    @if (_order is null) {
        <div class="flex items-center justify-center py-16">
            <div class="flex items-center gap-3 text-zinc-400">
                <span class="material-symbols-outlined animate-spin">refresh</span>
                <span class="text-sm">Loading order...</span>
            </div>
        </div>
    } else {

        <div class="bg-white rounded-xl shadow-sm border border-zinc-100 p-6">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                <div>
                    <p class="text-xs text-zinc-400 uppercase tracking-wider font-semibold mb-1">Order</p>
                    <p class="text-2xl font-bold text-zinc-900 font-lexend">#GH-@_order.OrderNumber</p>
                    <p class="text-sm text-zinc-500 mt-1">
                        <span class="material-symbols-outlined text-zinc-400" style="font-size:14px;vertical-align:middle">person</span>
                        @(string.IsNullOrEmpty(_order.CustomerName) ? "Unknown customer" : _order.CustomerName)
                    </p>
                    <p class="text-xs text-zinc-400 mt-1">@_order.CreatedAt.ToString("dd MMM yyyy, HH:mm")</p>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium mt-2 @StatusClass(_order.Status)">
                        @_order.Status
                    </span>
                </div>
                <div class="flex flex-wrap gap-2">
                    @if (_order.Status == OrderStatus.PENDING) {
                        <button class="gh-btn gh-btn-primary" @onclick="ConfirmAsync" disabled="@_busy">
                            @if (_busy) {
                                <span class="material-symbols-outlined animate-spin" style="font-size:16px">refresh</span>
                            } else {
                                <span class="material-symbols-outlined" style="font-size:16px">check_circle</span>
                            }
                            <span>Confirm</span>
                        </button>
                        <button class="gh-btn gh-btn-secondary" @onclick="CancelAsync" disabled="@_busy">
                            <span class="material-symbols-outlined" style="font-size:16px">cancel</span>
                            <span>Cancel</span>
                        </button>
                    } else if (_order.Status == OrderStatus.CONFIRMED) {
                        <button class="gh-btn gh-btn-secondary" @onclick="CancelAsync" disabled="@_busy">
                            @if (_busy) {
                                <span class="material-symbols-outlined animate-spin" style="font-size:16px">refresh</span>
                            } else {
                                <span class="material-symbols-outlined" style="font-size:16px">cancel</span>
                            }
                            <span>Cancel</span>
                        </button>
                    }
                    <a href="/orders" class="gh-btn gh-btn-secondary">
                        <span class="material-symbols-outlined" style="font-size:16px">arrow_back</span>
                        <span>Back</span>
                    </a>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="bg-white rounded-xl shadow-sm border border-zinc-100 p-5">
                <p class="text-xs text-zinc-400 uppercase tracking-wider font-semibold mb-1">Subtotal</p>
                <p class="text-xl font-bold text-zinc-900">R$ @_order.Subtotal.ToString("F2")</p>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-zinc-100 p-5">
                <p class="text-xs text-zinc-400 uppercase tracking-wider font-semibold mb-1">Discount</p>
                @if (_order.Discount > 0) {
                    <p class="text-xl font-bold text-emerald-600">-@_order.Discount%</p>
                } else {
                    <p class="text-xl font-bold text-zinc-400">—</p>
                }
            </div>
            <div class="bg-primary rounded-xl p-5">
                <p class="text-xs text-secondary-fixed uppercase tracking-wider font-semibold mb-1">Total</p>
                <p class="text-xl font-bold text-white">R$ @_order.Total.ToString("F2")</p>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-zinc-100 overflow-hidden">
            <div class="px-6 py-4 border-b border-zinc-100">
                <h2 class="text-sm font-semibold text-zinc-900">Order Items</h2>
            </div>
            <div class="divide-y divide-zinc-50">
                @foreach (var item in _order.Items) {
                    <div class="px-6 py-5">
                        <div class="flex items-start gap-4">
                            <div class="w-10 h-10 rounded-xl bg-amber-100 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-amber-600" style="font-size:20px;font-variation-settings:'FILL' 1">lunch_dining</span>
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center justify-between gap-2">
                                    <p class="text-sm font-semibold text-zinc-900">
                                        @(string.IsNullOrEmpty(item.MenuName) ? "Sandwich" : item.MenuName)
                                    </p>
                                    <p class="text-sm font-bold text-zinc-900">R$ @item.UnitPrice.ToString("F2")</p>
                                </div>
                                <p class="text-xs text-zinc-400 mt-0.5">Qty: @item.Qtd</p>

                                @if (item.SideDishes.Any()) {
                                    <div class="mt-3 space-y-2">
                                        <p class="text-xs font-semibold text-zinc-500 uppercase tracking-wider">Side Dishes</p>
                                        @foreach (var sd in item.SideDishes) {
                                            <div class="flex items-center gap-3 bg-zinc-50 rounded-lg px-3 py-2">
                                                <div class="w-6 h-6 rounded-md flex items-center justify-center shrink-0
                                                    @(sd.Category == SideDishCategory.FRIES ? "bg-amber-100" : "bg-blue-100")">
                                                    <span class="material-symbols-outlined @(sd.Category == SideDishCategory.FRIES ? "text-amber-600" : "text-blue-500")"
                                                          style="font-size:12px;font-variation-settings:'FILL' 1">
                                                        @(sd.Category == SideDishCategory.FRIES ? "fastfood" : "local_drink")
                                                    </span>
                                                </div>
                                                <span class="text-xs font-medium text-zinc-700 flex-1">
                                                    @(string.IsNullOrEmpty(sd.Name) ? sd.Category.ToString() : sd.Name)
                                                </span>
                                                <span class="text-xs text-zinc-400">Qty: @sd.Qtd</span>
                                                <span class="text-xs font-semibold text-zinc-900">R$ @sd.UnitPrice.ToString("F2")</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

    }

</div>

@code {
    [Parameter] public Guid Id { get; set; }
    private Toast _toast = default!;
    private OrderResponse? _order;
    private bool _busy;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync() {
        var result = await OrderSvc.GetByIdAsync(Id);
        if (result.IsSuccess) _order = result.Data;
        else await _toast.ShowAsync(result.ErrorMessage!);
    }

    private async Task ConfirmAsync() {
        _busy = true;
        var result = await OrderSvc.ConfirmAsync(Id);
        if (result.IsSuccess) _order = result.Data;
        else await _toast.ShowAsync(result.ErrorMessage!);
        _busy = false;
    }

    private async Task CancelAsync() {
        _busy = true;
        var result = await OrderSvc.CancelAsync(Id);
        if (result.IsSuccess) _order = result.Data;
        else await _toast.ShowAsync(result.ErrorMessage!);
        _busy = false;
    }

    private static string StatusClass(OrderStatus s) => s switch {
        OrderStatus.PENDING   => "bg-amber-100 text-amber-800",
        OrderStatus.CONFIRMED => "bg-blue-100 text-blue-800",
        OrderStatus.CANCELLED => "bg-zinc-100 text-zinc-600",
        OrderStatus.PAID      => "bg-emerald-100 text-emerald-800",
        OrderStatus.READY     => "bg-cyan-100 text-cyan-800",
        OrderStatus.DELIVERED => "bg-zinc-800 text-white",
        _                     => "bg-zinc-100 text-zinc-600"
    };
}
